# MASTER Trading — Environment Variables Template
# Copy this file to .env and fill in your actual credentials

# Etherscan API Key (Required for on-chain whale tracking)
# Obtain a free key at: https://etherscan.io/apis
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# CoinGecko API Key (Optional — for higher rate limits)
# Free tier available at: https://www.coingecko.com/en/api
COINGECKO_API_KEY=optional_coingecko_pro_key

# Exchange Credentials (Required for live CEX trading)
# BINANCE_API_KEY=your_binance_api_key
# BINANCE_API_SECRET=your_binance_api_secret

# Web3 Private Key (Required for on-chain DEX execution)
# WARNING: Never commit this value. Use AWS KMS or HashiCorp Vault in production.
# PRIVATE_KEY=0x_your_private_key_here

# RPC Endpoints (Required for Web3 execution)
# ETHEREUM_RPC=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# Data Cache Settings (Optional)
CACHE_ENABLED=true
CACHE_TTL=300

# Logging Level (Optional)
LOG_LEVEL=INFO
